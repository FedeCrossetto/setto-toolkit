{
  "name": "mytools-app",
  "version": "2.6.0",
  "description": "Setto — modular developer utilities",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "rebuild": "electron-rebuild -f -w node-pty",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "simple-git-hooks || true",
    "icons:build": "node scripts/generate-app-icon.mjs",
    "supabase:seed": "node scripts/seed-supabase-from-local.mjs",
    "supabase:seed:sql": "node scripts/generate-supabase-seed-sql.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@lezer/highlight": "^1.2.3",
    "@replit/codemirror-minimap": "^0.5.2",
    "@supabase/supabase-js": "^2.106.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "bufferutil": "^4.1.0",
    "chokidar": "^3.6.0",
    "codemirror": "^6.0.2",
    "devicon": "^2.17.0",
    "diff": "^5.2.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.0",
    "framer-motion": "^12.42.0",
    "fuse.js": "^7.0.0",
    "lucide-react": "^1.7.0",
    "openai": "^4.47.0",
    "react-icons": "^5.6.0",
    "utf-8-validate": "^6.0.6",
    "vscode-material-icons": "^0.1.1",
    "ws": "^8.21.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/rebuild": "^3.7.2",
    "@eslint/js": "^10.0.1",
    "@types/diff": "^5.2.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.0.0",
    "autoprefixer": "^10.4.19",
    "electron": "^43.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "lint-staged": "^17.0.8",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.3.1",
    "vitest": "^2.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged && npm run typecheck"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --max-warnings=0"
  },
  "build": {
    "appId": "com.devtoolkit.app",
    "productName": "Setto",
    "icon": "public/icon.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**/*",
      "out/renderer/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": "txt",
        "name": "Text File",
        "description": "Open with Setto",
        "role": "Editor"
      },
      {
        "ext": [
          "js",
          "ts",
          "tsx",
          "jsx",
          "json",
          "css",
          "html",
          "md",
          "py",
          "java",
          "cpp",
          "c",
          "cs",
          "go",
          "rs",
          "yaml",
          "yml",
          "xml",
          "sql"
        ],
        "name": "Source File",
        "description": "Open with Setto",
        "role": "Editor"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/app-icon-512.png"
    },
    "publish": {
      "provider": "github",
      "owner": "FedeCrossetto",
      "repo": "setto-toolkit"
    }
  }
}
