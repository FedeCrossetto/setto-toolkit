# ── Google OAuth 2.0 (Desktop App) ────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client ID (Desktop app)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GitHub OAuth App (Device Flow) ────────────────────────────────────────────
# github.com → Settings → Developer settings → OAuth Apps → New OAuth App
# Enable "Device Flow" → copy the Client ID (no secret needed).
# Once compiled in, users just click "Sign in with GitHub" — no setup required.
GITHUB_CLIENT_ID=Ov23liXXXXXXXXXXXXXX

# ── GitLab OAuth Application (Device Flow) ────────────────────────────────────
# gitlab.com → Preferences → Applications → New application
# Scopes: read_api  |  Enable "Device Authorization Grant" → copy Application ID.
# Once compiled in, users just click "Sign in with GitLab" — no setup required.
GITLAB_CLIENT_ID=your-gitlab-application-id
